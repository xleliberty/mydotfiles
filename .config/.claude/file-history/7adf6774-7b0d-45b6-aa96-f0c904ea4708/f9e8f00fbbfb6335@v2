-include .env
export

DB_HOST    ?= localhost
DB_PORT    ?= 5432
DB_NAME    ?= xsalto_fidelity
DB_USER    ?= postgres
DB_PASSWORD ?=

PSQL = PGPASSWORD="$(DB_PASSWORD)" psql -h $(DB_HOST) -p $(DB_PORT) -U $(DB_USER)

.PHONY: db import test

## Create database (if not exists) and apply table schema
db:
	@$(PSQL) -c "SELECT 1 FROM pg_database WHERE datname = '$(DB_NAME)'" \
		| grep -q 1 || $(PSQL) -c "CREATE DATABASE $(DB_NAME)"
	@$(PSQL) -d $(DB_NAME) -f database/tables.sql
	@echo "Database $(DB_NAME) is ready."

## Run the contact importer
import:
	php bin/import.php

## Run unit tests
test:
	vendor/bin/phpunit
